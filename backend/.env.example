# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
MONGODB_URI=
DATABASE_NAME=pitchforge

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# CORS & Allowed Hosts
# ---------------------------------------------------------------------------
FRONTEND_URLS=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver,*.onrender.com,*.railway.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=80
RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8000
